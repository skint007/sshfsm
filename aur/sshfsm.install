post_install() {
    cat <<'MSG'
==> sshfsm installs the 'sshm' command.
    Quick start:
      sshm --init        # initialize configuration
      sshm <hostname>    # mount a remote server
      sshm --help        # show all commands
==> Shell completion (bash and zsh) is available in new shell sessions.
==> Persistent mounts (-p) require an SSH identity file at:
      ~/.ssh/id_ed25519_<hostname>
MSG
}

post_upgrade() {
    post_install
}
